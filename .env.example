# FarmLink frontend — copy to .env.local (dev) or set in Vercel/hosting dashboard (production)

# Local dev
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Production — point to your deployed API (Render, Railway, Fly.io, etc.)
# NEXT_PUBLIC_API_URL=https://farmlink-api.onrender.com/api/v1

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
NEXT_PUBLIC_USE_MOCK_DATA=false

# Optional: map tiles (defaults to OpenStreetMap)
# NEXT_PUBLIC_MAP_PROVIDER=osm
# NEXT_PUBLIC_MAP_TOKEN=
