# ---------------------------------------------------------------------------
# FarmLink AI backend — example environment configuration
# Copy this file to `.env` and adjust values. Never commit real secrets.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=4000

# Database — Supabase (IPv4 networks: use Session pooler, NOT direct db.* host)
# Dashboard → Connect → ORM → Prisma → copy "Session pooler" URI (port 5432)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/farmlink?schema=public

# Authentication
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# CORS (comma separated list of allowed origins)
# Development:
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
# Production example (add your Vercel URL and custom domain):
# CORS_ORIGINS=https://farmlink.vercel.app,https://www.yourdomain.com,https://yourdomain.com

# Logging
LOG_LEVEL=debug

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# AI extraction provider (local = deterministic offline parser, no key required)
AI_PROVIDER=local
AI_API_KEY=
AI_MODEL=

# Seed / bootstrap administrator account (development only)
ADMIN_FULL_NAME=FarmLink Administrator
ADMIN_PHONE_NUMBER=+233200000000
ADMIN_EMAIL=admin@farmlink.local
ADMIN_PASSWORD=AdminPassword123!
